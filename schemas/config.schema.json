{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ayu-exorcist/kimi-registry-adapter/schemas/config.schema.json",
  "title": "kimi-registry-adapter config",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1,
      "description": "Path or URL to the JSON Schema for this config file"
    },
    "server": {
      "default": {
        "host": "127.0.0.1",
        "port": 2727
      },
      "type": "object",
      "properties": {
        "host": {
          "default": "127.0.0.1",
          "type": "string",
          "minLength": 1
        },
        "port": {
          "default": 2727,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false
    },
    "update": {
      "default": {
        "mode": "merge"
      },
      "type": "object",
      "properties": {
        "mode": {
          "default": "merge",
          "type": "string",
          "enum": ["merge", "overwrite"]
        }
      },
      "additionalProperties": false
    },
    "providers": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "baseUrl": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "default": "openai_responses",
            "type": "string",
            "enum": ["anthropic", "openai", "openai_responses"]
          },
          "modelSource": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": ["openai_models", "anthropic_models"]
                  },
                  "modelsUrl": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["kind"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "local_file"
                  },
                  "path": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["kind", "path"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "remote_url"
                  },
                  "url": {
                    "type": "string",
                    "minLength": 1
                  },
                  "auth": {
                    "type": "string",
                    "enum": ["none", "provider"],
                    "default": "none",
                    "description": "Credential policy for remote payload fetching. Use provider only when the remote URL is trusted to receive this provider's API key."
                  }
                },
                "required": ["kind", "url"],
                "additionalProperties": false
              }
            ]
          },
          "modelsMetadataPath": {
            "type": "string",
            "minLength": 1
          },
          "apiKeyEnv": {
            "type": "string",
            "minLength": 1
          },
          "updateMode": {
            "type": "string",
            "enum": ["merge", "overwrite"]
          },
          "preserveUnknownModels": {
            "type": "boolean",
            "description": "Keep locally added models during merge updates even when they are absent from the latest generated registry"
          },
          "npm": {
            "type": "string",
            "minLength": 1
          },
          "fallbackContext": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "fallbackToolCall": {
            "type": "boolean"
          },
          "include": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "exclude": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "overrides": {
            "type": "object",
            "propertyNames": {
              "type": "string",
              "minLength": 1
            },
            "additionalProperties": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "family": {
                  "type": "string",
                  "minLength": 1
                },
                "limit": {
                  "type": "object",
                  "properties": {
                    "context": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "output": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "additionalProperties": false
                },
                "tool_call": {
                  "type": "boolean"
                },
                "reasoning": {
                  "type": "boolean"
                },
                "interleaved": {
                  "type": "boolean"
                },
                "support_efforts": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "default_effort": {
                  "type": "string",
                  "minLength": 1
                },
                "modalities": {
                  "type": "object",
                  "properties": {
                    "input": {
                      "minItems": 1,
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": ["text", "image", "audio", "video"]
                      }
                    },
                    "output": {
                      "minItems": 1,
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": ["text", "image", "audio", "video"]
                      }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        },
        "required": ["name", "baseUrl"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "required": []
}
